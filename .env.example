# AI服务配置
# 选择AI服务提供商: openai, anthropic, siliconflow, mock
AI_PROVIDER=mock

# OpenAI配置
# OPENAI_API_KEY=sk-xxx
# OPENAI_MODEL=gpt-4o-mini

# Anthropic配置
# ANTHROPIC_API_KEY=sk-xxx
# ANTHROPIC_MODEL=claude-3-haiku-20240307

# 硅基流动配置
# SILICONFLOW_API_KEY=sk-xxx
# SILICONFLOW_MODEL=Qwen/Qwen2.5-7B-Instruct

# GitHub Token（可选，提高API请求限制）
# GITHUB_TOKEN=ghp_xxx

# 子函数分析专用配置（可选，用于降低成本）
# SUBFUNCTION_AI_PROVIDER=siliconflow
# SUBFUNCTION_AI_MODEL=Qwen/Qwen2.5-32B-Instruct
# SUBFUNCTION_AI_API_KEY=your-api-key

# 递归分析配置
MAX_RECURSION_DEPTH=3
ENABLE_RECURSIVE_ANALYSIS=true

# 函数定位AI配置（可选，用于阶段2推测）
# FUNCTION_LOCATION_AI_PROVIDER=siliconflow
# FUNCTION_LOCATION_AI_MODEL=Qwen/Qwen2.5-7B-Instruct
